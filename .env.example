# Ports
PUBLIC_PORT=3001
ADMIN_PORT=3002

# Database
DATABASE_PATH=./data/meridian.db

# Sessions
SESSION_SECRET=changeme_use_random_32_bytes

# Cloudflare
TRUST_CF_HEADERS=true

# Data retention (days)
RETENTION_RAW_DAYS=7
RETENTION_5MIN_DAYS=30
RETENTION_1HOUR_DAYS=365

# Probe defaults
DEFAULT_PROBE_INTERVAL=60
DEFAULT_PACKET_COUNT=10

# Node env
NODE_ENV=production
